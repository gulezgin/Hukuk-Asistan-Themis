# ============================================================
#  RAG Lawyer — Ortam Değişkenleri (.env)
# ============================================================
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.
# ÖNEMLİ: .env dosyasını asla Git'e push etmeyin!

# --- Embedding Modeli ---
# Türkçe için önerilen: BAAI/bge-m3 (güçlü, çok dilli)
# Hafif alternatif: intfloat/multilingual-e5-small
EMBEDDING_MODEL=BAAI/bge-m3
FAISS_METRIC=cosine

# --- LLM Sağlayıcı ---
# Seçenekler: openai | groq | custom
LLM_PROVIDER=groq

# OpenAI (ücretli)
OPENAI_API_KEY=

# Groq (ücretsiz kota)
GROQ_API_KEY=<your-groq-api-key>
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model seçimi
# Groq: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768
# OpenAI: gpt-4.1-nano, gpt-4o-mini, gpt-4o
LLM_MODEL=llama-3.1-8b-instant
