# OpenAI (ücretli) - kullanmıyorsan boş bırak
OPENAI_API_KEY=

# Embedding (C: daha iyi model)
# Örn: BAAI/bge-m3 (daha güçlü, daha ağır) veya BAAI/bge-small-en-v1.5 (hafif)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FAISS_METRIC=cosine

# LLM Provider (B: ücretsiz kota için örnek Groq)
LLM_PROVIDER=groq
GROQ_API_KEY=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
# Groq OpenAI-compatible endpoint (genelde değiştirmene gerek yok)
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Örnek modeller: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768 (hesabına göre)
LLM_MODEL=llama-3.1-8b-instant
